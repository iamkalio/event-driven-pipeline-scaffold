ENVIRONMENT=local
LOG_LEVEL=INFO
APP_NAME=oligo-backend
API_HOST=0.0.0.0
API_PORT=8000
API_DEFAULT_LIMIT=50
API_MAX_LIMIT=200
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RUNTIME=runtime-events
KAFKA_TOPIC_THREAT=threat-events
KAFKA_TOPIC_DLQ=runtime-events-dlq
KAFKA_AUTO_OFFSET_RESET=latest
KAFKA_PRODUCER_RETRIES=3
CONSUMER_MAX_RETRIES=3
POSTGRES_DSN=postgresql://oligo:oligo@postgres:5432/oligo
PGBOUNCER_DSN=postgresql://oligo:oligo@postgres:5432/oligo
POSTGRES_POOL_MIN_SIZE=5
POSTGRES_POOL_MAX_SIZE=20
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_BLOOM_KEY=oligo:processed-events:bloom
JOIN_TTL_MS=200
PENDING_WRITE_DELAY_MS=250
ALERT_COOLDOWN_SECONDS=900
HTTP_TIMEOUT_SECONDS=5.0
AI_INLINE_SCORE_TIMEOUT_MS=10
AI_MODEL_SERVER_URL=dns:///model-server:50051
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/example/example/example
JIRA_BASE_URL=https://example.atlassian.net
JIRA_API_TOKEN=change-me
